@model ParkingLot.Models.ParkingSnapshotViewModel

<div class="snapshot-header">
    <div class="snapshot-info">
        <span class="info-badge">
            Total Spots: <strong>@Model.TotalSpots</strong>
        </span>
        <span class="info-badge">
            Hourly Fee: <strong>$@Model.HourlyFee.ToString("0.00")</strong>
        </span>
    </div>
    <div class="available-count">
        Available Spots: <span class="available-number @(Model.AvailableSpots == 0 ? "text-danger" : "text-success")">@Model.AvailableSpots</span>
    </div>
</div>

@if (Model.ParkedCars.Count == 0)
{
    <div class="empty-lot">
        <p>No cars currently parked</p>
    </div>
}
else
{
    <table class="table parking-table">
        <thead>
            <tr>
                <th>Tag Number</th>
                <th>Time In</th>
                <th>Elapsed Time</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var car in Model.ParkedCars)
            {
                <tr>
                    <td class="tag-cell">@car.TagNumber</td>
                    <td>@car.CheckInTime</td>
                    <td>@car.ElapsedTime</td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="snapshot-footer">
    Spots taken: <strong>@Model.SpotsTaken</strong>
</div>
